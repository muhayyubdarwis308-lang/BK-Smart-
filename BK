function selP(qid,idx,el){document.querySelectorAll(`#qop_${qid} .qo`).forEach(o=>o.classList.remove('sel'));el.classList.add('sel');const q=findSoal(qid);ans[qid]=q?q.opsi[idx]:'';syncPN();}
function togG(qid,idx,el){if(!gandaSt[qid])gandaSt[qid]=new Set();el.classList.toggle('sel');const cb=el.querySelector('.qcb');if(el.classList.contains('sel')){gandaSt[qid].add(idx);cb.textContent='✓';}else{gandaSt[qid].delete(idx);cb.textContent='';}const q=findSoal(qid);ans[qid]=q?[...gandaSt[qid]].sort().map(i=>q.opsi[i]).join(', '):'';syncPN();}
