  document.getElementById('mPT').textContent='Edit Paket';
  document.getElementById('inNP').value=p.nama;document.getElementById('inDP').value=p.desc||'';
  document.getElementById('inBP').value=p.bidang||'pribadi';document.getElementById('inCP').value=p.color||'bl';document.getElementById('inIP').value=p.icon||'📋';
  document.getElementById('inBP').parentElement.parentElement.style.display=p.jenis==='akpd'?'':'none';
  om('mPaket');
}
function simpanPaket(){
  const nama=document.getElementById('inNP').value.trim();if(!nama){toast('Nama paket wajib diisi','error');return;}
  const jenis=document.getElementById('mPJ').value;
  const data={nama,jenis,desc:document.getElementById('inDP').value.trim(),color:document.getElementById('inCP').value,icon:document.getElementById('inIP').value,bidang:jenis==='akpd'?document.getElementById('inBP').value:null};
  const list=jenis==='akpd'?DB.akpdList:DB.sosioList;
  if(editPaketId){const i=list.findIndex(p=>p.id===editPaketId);if(i>-1)list[i]={...list[i],...data};toast('Paket diperbarui','success');}
  else{list.push({id:uid(),...data,soal:[]});toast('Paket dibuat','success');}
  saveDB();cm('mPaket');renderPaketGrid(jenis);
}

// ── KELOLA SOAL ──
function openKelolaSoal(pid){
  const p=findPaket(pid);if(!p)return;
  activePSoal=pid;document.getElementById('mKST').textContent=p.nama;document.getElementById('mKSI').textContent=p.bidang?`${BIDANG[p.bidang]?.icon} ${BIDANG[p.bidang]?.label} • ${p.desc||''}`:p.desc||'';
  renderSoalList(p);om('mKS');
}
function renderSoalList(p){
  document.getElementById('jmlSL').textContent=`${p.soal.length} soal`;
  const el=document.getElementById('soalLP');
  if(!p.soal.length){el.innerHTML=`<div class="emp"><div class="emp-i">📝</div><div class="emp-t">Belum ada soal</div></div>`;return;}
  el.innerHTML=p.soal.map((q,i)=>`<div class="sit">
    <div class="sm"><div class="stx">${i+1}. ${q.teks}</div>
    <div class="sinf"><span class="bdg ${tc(q.tipe)}">${tl(q.tipe)}</span>${q.tipe==='sosio_pilih'?`<span class="tx tm">Pilih ${q.config?.jumlah||2} teman</span>`:''}${q.opsi&&q.opsi.length?`<span class="tx tm">${q.opsi.slice(0,3).join(' · ')}${q.opsi.length>3?'…':''}</span>`:''}</div></div>
    <div class="ta" style="flex-shrink:0"><button class="btn btn-g btn-sm" onclick="openEditSoal(${q.id})">✏️</button><button class="btn btn-d btn-sm" onclick="hapusSoal(${q.id})">🗑</button></div>
  </div>`).join('');
}
function openAddSoal(){
  editSoalId=null;const p=findPaket(activePSoal);
  document.getElementById('mSoalT').textContent='Tambah Soal';document.getElementById('mSJ').value=p?p.jenis:'akpd';
  document.getElementById('inTS').value='';document.getElementById('inTiS').value=p&&p.jenis==='sosiometri'?'sosio_pilih':'pilihan';
  document.getElementById('lKi').value='Sangat Tidak Setuju';document.getElementById('lKa').value='Sangat Setuju';
  document.getElementById('sMn').value=0;document.getElementById('sMx').value=100;document.getElementById('sDF').value=50;document.getElementById('sUT').value='';
  document.getElementById('inSJml').value=2;
  resetOpsi(['','','']);onTipe();om('mSoal');
}
function openEditSoal(qid){
  const p=findPaket(activePSoal);if(!p)return;const q=p.soal.find(s=>s.id===qid);if(!q)return;
  editSoalId=qid;document.getElementById('mSoalT').textContent='Edit Soal';document.getElementById('mSJ').value=p.jenis;
  document.getElementById('inTS').value=q.teks;document.getElementById('inTiS').value=q.tipe;
  const c=q.config||{};
  document.getElementById('lKi').value=c.labelKiri||'Sangat Tidak Setuju';document.getElementById('lKa').value=c.labelKanan||'Sangat Setuju';
  document.getElementById('sMn').value=c.min??0;document.getElementById('sMx').value=c.max??100;document.getElementById('sDF').value=c.default??50;document.getElementById('sUT').value=c.unit||'';
  document.getElementById('inSJml').value=c.jumlah||2;
  resetOpsi(q.opsi&&q.opsi.length?q.opsi:['']);onTipe();om('mSoal');
}
function onTipe(){
  const t=document.getElementById('inTiS').value;
  document.getElementById('opC').style.display=['pilihan','ganda','urutan'].includes(t)?'':'none';
  document.getElementById('lkC').style.display=t==='likert'?'':'none';
  document.getElementById('slC').style.display=t==='slider'?'':'none';
  document.getElementById('soC').style.display=t==='sosio_pilih'?'':'none';
}
function resetOpsi(arr){const el=document.getElementById('opLB');el.innerHTML='';arr.forEach(v=>addOpsi(v));}
function addOpsi(val=''){const el=document.getElementById('opLB');const div=document.createElement('div');div.className='oib';div.innerHTML=`<input class="inp" value="${val}" placeholder="Teks pilihan..."><button class="btn btn-d btn-sm" style="flex-shrink:0" onclick="this.parentElement.remove()">✕</button>`;el.appendChild(div);}
function simpanSoal(){
  const p=findPaket(activePSoal);if(!p)return;
  const teks=document.getElementById('inTS').value.trim();if(!teks){toast('Teks soal wajib diisi','error');return;}
  const tipe=document.getElementById('inTiS').value;
  const needsOpsi=['pilihan','ganda','urutan'].includes(tipe);
  let opsi=[];if(needsOpsi){opsi=[...document.querySelectorAll('#opLB .oib input')].map(i=>i.value.trim()).filter(Boolean);if(opsi.length<2){toast('Minimal 2 pilihan','error');return;}}
  let config={};
  if(tipe==='likert')config={labelKiri:document.getElementById('lKi').value,labelKanan:document.getElementById('lKa').value};
  if(tipe==='slider')config={min:parseInt(document.getElementById('sMn').value),max:parseInt(document.getElementById('sMx').value),default:parseInt(document.getElementById('sDF').value),unit:document.getElementById('sUT').value};
  if(tipe==='sosio_pilih')config={jumlah:parseInt(document.getElementById('inSJml').value)};
  if(editSoalId){const i=p.soal.findIndex(s=>s.id===editSoalId);if(i>-1)p.soal[i]={...p.soal[i],teks,tipe,opsi,config};toast('Soal diperbarui','success');}
  else{p.soal.push({id:uid(),teks,tipe,opsi,config});toast('Soal ditambahkan','success');}
  saveDB();cm('mSoal');renderSoalList(p);renderPaketGrid(p.jenis);
}
function hapusSoal(qid){const p=findPaket(activePSoal);if(!p)return;p.soal=p.soal.filter(s=>s.id!==qid);saveDB();renderSoalList(p);renderPaketGrid(p.jenis);toast('Soal dihapus','success');}

// ── DATA SISWA ──
function popSiswaFilter(){document.getElementById('fKS').innerHTML='<option value="">Semua Kelas</option>'+DB.kelasList.map(k=>`<option>${k}</option>`).join('');}
function renderTblSiswa(){
  let data=[...DB.siswaList];
  const srch=(document.getElementById('srS')?.value||'').toLowerCase();
  const kls=document.getElementById('fKS')?.value||'';
  if(srch)data=data.filter(s=>s.nama.toLowerCase().includes(srch)||s.nis.includes(srch));
  if(kls)data=data.filter(s=>s.kelas===kls);
  const tbody=document.getElementById('tblSB');
  if(!data.length){tbody.innerHTML=`<tr><td colspan="7" style="text-align:center;padding:36px;color:var(--tx3)">Tidak ada data</td></tr>`;return;}
  tbody.innerHTML=data.map((s,i)=>`<tr>
    <td style="color:var(--tx3)">${i+1}</td>
    <td><strong>${s.nama}</strong></td>
    <td><span style="font-family:monospace;font-size:13px;background:var(--acs);color:var(--ac2);padding:2px 8px;border-radius:6px">${s.nis}</span></td>
    <td>${s.kelas}</td>
    <td style="color:var(--tx3);letter-spacing:.05em">••••••</td>
    <td>${s.aktif!==false?'<span class="bdg bg-gn">Aktif</span>':'<span class="bdg bg-rd">Non-aktif</span>'}</td>
    <td><div class="ta"><button class="btn btn-g btn-sm" onclick="openEditSiswa(${s.id})">✏️ Edit</button><button class="btn btn-d btn-sm" onclick="konfHapus('siswa',${s.id})">🗑</button></div></td>
  </tr>`).join('');
}
function openAddSiswa(){
  editSiswaId=null;document.getElementById('mSiswaT').textContent='Tambah Siswa';
  document.getElementById('inNS').value='';document.getElementById('inNiS').value='';document.getElementById('inPaS').value='';
  document.getElementById('inKS').innerHTML=DB.kelasList.map(k=>`<option>${k}</option>`).join('');om('mSiswa');
}
function openEditSiswa(id){
  const s=DB.siswaList.find(x=>x.id===id);if(!s)return;
  editSiswaId=id;document.getElementById('mSiswaT').textContent='Edit Siswa';
  document.getElementById('inNS').value=s.nama;document.getElementById('inNiS').value=s.nis;document.getElementById('inPaS').value=s.password;
  document.getElementById('inKS').innerHTML=DB.kelasList.map(k=>`<option ${k===s.kelas?'selected':''}>${k}</option>`).join('');om('mSiswa');
}
function simpanSiswa(){
  const nama=document.getElementById('inNS').value.trim();const nis=document.getElementById('inNiS').value.trim();
  const kelas=document.getElementById('inKS').value;const pass=document.getElementById('inPaS').value.trim();
  if(!nama||!nis||!kelas||!pass){toast('Semua field wajib diisi','error');return;}
  if(DB.siswaList.find(s=>s.nis===nis&&s.id!==editSiswaId)){toast('NIS sudah digunakan','error');return;}
  if(editSiswaId){const i=DB.siswaList.findIndex(s=>s.id===editSiswaId);if(i>-1)DB.siswaList[i]={...DB.siswaList[i],nama,nis,kelas,password:pass};toast('Data siswa diperbarui','success');}
  else{DB.siswaList.push({id:uid(),nama,nis,kelas,password:pass,aktif:true});toast('Siswa ditambahkan','success');}
  saveDB();cm('mSiswa');renderTblSiswa();
}

// ── DATA KELAS ──
function renderTblKelas(){
  const tbody=document.getElementById('tblKB');
  if(!DB.kelasList.length){tbody.innerHTML=`<tr><td colspan="4" style="text-align:center;padding:36px;color:var(--tx3)">Belum ada kelas</td></tr>`;return;}
  tbody.innerHTML=DB.kelasList.map((k,i)=>`<tr>
    <td style="color:var(--tx3)">${i+1}</td>
    <td><strong>${k}</strong></td>
    <td><span class="bdg bg-bl">${DB.siswaList.filter(s=>s.kelas===k).length} siswa</span></td>
    <td><div class="ta"><button class="btn btn-g btn-sm" onclick="openEditKelas('${k}')">✏️</button><button class="btn btn-d btn-sm" onclick="konfHapus('kelas','${k}')">🗑</button></div></td>
  </tr>`).join('');
}
function openAddKelas(){editKelasOld=null;document.getElementById('mKelasT').textContent='Tambah Kelas';document.getElementById('inNK').value='';om('mKelas');}
function openEditKelas(n){editKelasOld=n;document.getElementById('mKelasT').textContent='Edit Kelas';document.getElementById('inNK').value=n;om('mKelas');}
function simpanKelas(){
  const nama=document.getElementById('inNK').value.trim();if(!nama){toast('Nama kelas wajib diisi','error');return;}
  if(editKelasOld){const i=DB.kelasList.indexOf(editKelasOld);if(i>-1)DB.kelasList[i]=nama;DB.siswaList.forEach(s=>{if(s.kelas===editKelasOld)s.kelas=nama;});toast('Kelas diperbarui','success');}
  else{if(DB.kelasList.includes(nama)){toast('Kelas sudah ada','error');return;}DB.kelasList.push(nama);toast('Kelas ditambahkan','success');}
  saveDB();cm('mKelas');renderTblKelas();
}

// ── HAPUS ──
function konfHapus(type,id){
  const descs={paket:'Hapus paket ini? Semua jawaban terkait akan hilang.',siswa:'Hapus siswa ini? Data jawaban juga akan dihapus.',kelas:'Hapus kelas ini? Siswa tidak ikut terhapus.'};
  document.getElementById('mHD').textContent=descs[type]||'Yakin hapus?';
  document.getElementById('btnHOK').onclick=()=>{
    if(type==='paket'){const p=findPaket(id);const j=p?p.jenis:'akpd';if(j==='akpd')DB.akpdList=DB.akpdList.filter(p=>p.id!==id);else DB.sosioList=DB.sosioList.filter(p=>p.id!==id);DB.jawaban=DB.jawaban.filter(j=>j.paketId!==id);renderPaketGrid(j);}
    if(type==='siswa'){DB.siswaList=DB.siswaList.filter(s=>s.id!==id);DB.jawaban=DB.jawaban.filter(j=>j.siswaId!==id);renderTblSiswa();}
    if(type==='kelas'){DB.kelasList=DB.kelasList.filter(k=>k!==id);renderTblKelas();}
    saveDB();cm('mHapus');toast('Data berhasil dihapus','success');
  };
  om('mHapus');
}

sp('pg-login');
</script>
