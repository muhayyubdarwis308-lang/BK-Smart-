  if(!kelas){toast('Pilih kelas terlebih dahulu','error');return;}
  const siswaKelas = DB.siswaList.filter(s=>s.kelas===kelas);
  const jw = DB.jawaban.filter(j=>j.kelas===kelas&&j.jenis==='sosiometri');
  const head = ['Nama','NIS','Total Dipilih'];
  const voteCount = {};siswaKelas.forEach(s=>voteCount[s.id]=0);
  jw.forEach(j=>{
    const p=findPaket(j.paketId);if(!p)return;
    p.soal.filter(q=>q.tipe==='sosio_pilih').forEach(q=>{
      String(j.jawaban[q.id]||'').split(', ').filter(Boolean).forEach(name=>{
        const t=siswaKelas.find(s=>s.nama===name);if(t)voteCount[t.id]=(voteCount[t.id]||0)+1;
