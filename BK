}

function renderAnalisisSosio(){
  const kelas = document.getElementById('anSosioKelas').value;
  const paketSel = document.getElementById('anSosioPaket').value;
  const cont = document.getElementById('analSosioContent');
  if(!kelas){cont.innerHTML=`<div class="emp"><div class="emp-i">🏫</div><div class="emp-t">Pilih kelas untuk melihat analisis</div></div>`;return;}

  const siswaKelas = DB.siswaList.filter(s=>s.kelas===kelas);
  if(!siswaKelas.length){cont.innerHTML=`<div class="emp"><div class="emp-i">👥</div><div class="emp-t">Tidak ada siswa di kelas ini</div></div>`;return;}

  let paketList = DB.sosioList;
  if(paketSel) paketList = paketList.filter(p=>p.id===parseInt(paketSel));

  const jawabanKelas = DB.jawaban.filter(j=>j.kelas===kelas&&j.jenis==='sosiometri'&&(!paketSel||j.paketId===parseInt(paketSel)));

  // Hitung vote received per siswa (akumulasi semua soal semua paket)
  const voteCount = {}; // siswaId -> jumlah dipilih
  siswaKelas.forEach(s=>{voteCount[s.id]=0;});

  jawabanKelas.forEach(jw=>{
    const p = findPaket(jw.paketId);
    if(!p) return;
    p.soal.filter(q=>q.tipe==='sosio_pilih').forEach(q=>{
      const chosenNames = String(jw.jawaban[q.id]||'').split(', ').filter(Boolean);
      chosenNames.forEach(name=>{
        const target = siswaKelas.find(s=>s.nama===name);
        if(target) voteCount[target.id]=(voteCount[target.id]||0)+1;
      });
    });
  });

  const mengisi = jawabanKelas.map(j=>j.siswaId);
  const belumIsi = siswaKelas.filter(s=>!mengisi.includes(s.id));
  const tidakDipilih = siswaKelas.filter(s=>(voteCount[s.id]||0)===0&&mengisi.includes(s.id));

  // Ranking
  const ranking = siswaKelas.map(s=>({...s,votes:voteCount[s.id]||0})).sort((a,b)=>b.votes-a.votes);

  let html = '';

  // Header info
  html += `<div style="background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:space-between">
    <div style="display:flex;align-items:center;gap:16px">
      <div style="font-size:32px">🏫</div>
      <div><div style="font-family:'Fraunces',serif;font-size:18px;font-weight:700">Kelas ${kelas}</div>
      <div style="font-size:13px;color:var(--tx3)">${siswaKelas.length} siswa • ${jawabanKelas.length} respons masuk</div></div>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <div style="text-align:center"><div style="font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--green)">${jawabanKelas.length}</div><div style="font-size:11px;color:var(--tx3)">Sudah Isi</div></div>
      <div style="text-align:center"><div style="font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--red)">${belumIsi.length}</div><div style="font-size:11px;color:var(--tx3)">Belum Isi</div></div>
      <div style="text-align:center"><div style="font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--amber)">${tidakDipilih.length}</div><div style="font-size:11px;color:var(--tx3)">Terisolasi</div></div>
    </div>
  </div>`;

  // Alert terisolasi
  if(tidakDipilih.length){
    html += `<div class="sosio-isolated">⚠️ <strong>Siswa yang tidak dipilih siapapun (potensi terisolasi):</strong> ${tidakDipilih.map(s=>s.nama).join(', ')} — perlu perhatian khusus dari Guru BK!</div>`;
  }
  if(belumIsi.length){
    html += `<div class="sosio-alert">❌ <strong>Belum mengisi sosiometri:</strong> ${belumIsi.map(s=>s.nama).join(', ')}</div>`;
  }

  // Ranking paling banyak dipilih
  html += `<div style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;margin-bottom:14px">🏆 Ranking Popularitas (Total Dipilih)</div>`;
  html += `<div class="sosio-rank-grid">`;
  ranking.forEach((s,i)=>{
    const rnClass = i===0?'rn1':i===1?'rn2':i===2?'rn3':'rn4';
    const bar = siswaKelas.length>1?Math.round(s.votes/(ranking[0]?.votes||1)*100):0;
    html += `<div class="rank-card">
      <div class="rank-num ${rnClass}">${i+1}</div>
      <div class="rank-info">
        <div class="rank-nama">${s.nama}</div>
        <div class="rank-count">${s.votes} kali dipilih</div>
        <div class="pb" style="margin-top:5px"><div class="pf pf-pk" style="width:${bar}%"></div></div>
      </div>
    </div>`;
  });
  html += `</div>`;

  // Matrix Sosiometri per soal per paket
  paketList.forEach(p=>{
    const jwPaket = jawabanKelas.filter(j=>j.paketId===p.id);
    if(!jwPaket.length) return;

    html += `<div style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;margin-bottom:12px;margin-top:20px">${p.icon||'🤝'} ${p.nama} — Matrix Sosiometri</div>`;

    p.soal.filter(q=>q.tipe==='sosio_pilih').forEach(q=>{
      html += `<div style="margin-bottom:18px">
        <div style="font-size:13px;font-weight:500;margin-bottom:10px;color:var(--tx2)">📌 ${q.teks}</div>`;

      // Build matrix: baris = pemilih, kolom = yang dipilih
      html += `<div class="sosio-matrix"><table>
        <thead><tr><th>Pemilih ↓ / Dipilih →</th>${siswaKelas.map(s=>`<th style="writing-mode:vertical-rl;text-orientation:mixed;height:80px;padding:8px 6px">${s.nama.split(' ')[0]}</th>`).join('')}<th>Total Dipilih</th></tr></thead>
        <tbody>`;

      const colVotes = {};
      siswaKelas.forEach(s=>colVotes[s.id]=0);

      siswaKelas.forEach(pemilih=>{
        const jw = jwPaket.find(j=>j.siswaId===pemilih.id);
        const chosenNames = jw?String(jw.jawaban[q.id]||'').split(', ').filter(Boolean):[];
        const chosenIds = new Set(chosenNames.map(name=>{const t=siswaKelas.find(s=>s.nama===name);return t?t.id:null;}).filter(Boolean));
        chosenIds.forEach(id=>colVotes[id]=(colVotes[id]||0)+1);
        html += `<tr><td>${pemilih.nama}</td>`;
        siswaKelas.forEach(dipilih=>{
          if(dipilih.id===pemilih.id){html+=`<td class="cell-self">—</td>`;}
          else if(chosenIds.has(dipilih.id)){html+=`<td class="cell-pick">✓</td>`;}
          else{html+=`<td></td>`;}
        });
        html += `<td style="font-weight:600;color:var(--tx2)">0</td></tr>`;
      });

      // Baris total
      html += `<tr style="background:var(--sf2)"><td style="font-weight:600">Total Memilih</td>`;
      siswaKelas.forEach(s=>html+=`<td style="font-weight:700;color:var(--ac2)">${colVotes[s.id]||0}</td>`);
      html += `<td></td></tr>`;

      html += `</tbody></table></div>`;

      // Legenda
      html += `<div class="sosio-legend">
        <div class="leg-item"><div style="width:18px;height:18px;border-radius:4px;background:var(--acs);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--ac2)">✓</div><span>Dipilih</span></div>
        <div class="leg-item"><div style="width:18px;height:18px;border-radius:4px;background:var(--sf3);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--tx3)">—</div><span>Diri sendiri</span></div>
        <div class="leg-item"><div style="width:18px;height:18px;border-radius:4px;background:var(--sf2);border:1px solid var(--bd)"></div><span>Tidak dipilih</span></div>
      </div>`;
      html += `</div>`; // end soal
    });
  });

  // Analisis simpulan
  html += `<div style="background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:18px;margin-top:20px">
    <div style="font-family:'Fraunces',serif;font-size:15px;font-weight:600;margin-bottom:14px">💡 Simpulan & Rekomendasi</div>`;

  const topStar = ranking[0];
  const bottomStar = ranking.filter(s=>s.votes>0).pop();
  if(topStar&&topStar.votes>0) html+=`<div class="ab"><div class="aq">⭐ Siswa paling populer</div><div class="aa">${topStar.nama} (${topStar.votes} kali dipilih) — berpotensi menjadi pemimpin kelompok</div></div>`;
  if(tidakDipilih.length) html+=`<div class="ab" style="border-color:var(--amber)"><div class="aq">⚠️ Siswa terisolasi (tidak dipilih siapapun)</div><div class="aa">${tidakDipilih.map(s=>s.nama).join(', ')} — perlu intervensi BK untuk membantu adaptasi sosial</div></div>`;
  if(belumIsi.length) html+=`<div class="ab" style="border-color:var(--red)"><div class="aq">❌ Data tidak lengkap</div><div class="aa">${belumIsi.map(s=>s.nama).join(', ')} belum mengisi — analisis mungkin tidak akurat</div></div>`;

  html += `</div>`;

  cont.innerHTML = html;
}

function eksporSosio(){
