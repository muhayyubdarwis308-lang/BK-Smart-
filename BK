  if(!paketList.length){cont.innerHTML=`<div class="emp"><div class="emp-i">📊</div><div class="emp-t">Tidak ada paket untuk bidang ini</div></div>`;return;}

  const kelasTampil = kelasSel === 'SEMUA' ? 'Semua Kelas' : kelasSel;

  let html = `<div style="background:var(--sf2);border:1px solid var(--bd);border-radius:var(--r);padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
    <div style="font-size:32px">${kelasSel==='SEMUA'?'🌐':'🏫'}</div>
    <div><div style="font-family:'Fraunces',serif;font-size:18px;font-weight:700">${kelasTampil}</div>
    <div style="font-size:13px;color:var(--tx3)">${siswaList.length} siswa • ${paketList.length} paket dianalisis</div></div>
  </div>`;

  // Bidang ringkasan (only on 'all')
  if(curBidang === 'all'){
    html += `<div style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;margin-bottom:14px">📊 Ringkasan Skor per Bidang</div>`;
    html += `<div class="bidang-score-grid">`;
    Object.entries(BIDANG).forEach(([key,bd])=>{
      const bPaket = DB.akpdList.filter(p=>p.bidang===key);
      if(!bPaket.length){return;}
      const allScores = [];
      siswaList.forEach(s=>{
        bPaket.forEach(p=>{
          const jw = DB.jawaban.find(j=>j.siswaId===s.id&&j.paketId===p.id);
          if(!jw)return;
          p.soal.forEach(q=>{
            const skor = hitungSkorSoal(q, jw.jawaban);
            if(skor !== null) allScores.push(skor);
          });
        });
      });
      const avg = allScores.length ? (allScores.reduce((a,b)=>a+b,0)/allScores.length).toFixed(2) : '—';
      const pct = allScores.length ? Math.round((parseFloat(avg)-1)/4*100) : 0;
      const {icon,label,pfClass} = bd;
      html += `<div class="bsc">
        <div class="bsc-header"><div style="font-size:22px">${icon}</div><div class="bsc-skor" style="color:var(--${bd.color==='green'?'green':bd.color==='amber'?'amber':bd.color==='purple'?'purple':'teal'})">${avg}</div></div>
        <div class="bsc-nama" style="margin-bottom:8px">${label}</div>
        <div class="pb"><div class="pf ${pfClass}" style="width:${pct}%"></div></div>
        <div style="font-size:11px;color:var(--tx3);margin-top:5px">${allScores.length} respons numerik</div>
      </div>`;
    });
    html += `</div>`;
  }

  // Detail per paket
  paketList.forEach(p=>{
    const bInfo = BIDANG[p.bidang] || {icon:'📋',label:p.bidang||'',color:'green',pfClass:'pf-bl'};
    html += `<div style="background:var(--sf);border:1px solid var(--bd);border-radius:var(--r);padding:18px;margin-bottom:16px">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
        <div style="font-size:24px">${p.icon||'📋'}</div>
        <div>
          <div style="font-family:'Fraunces',serif;font-size:16px;font-weight:600">${p.nama}</div>
          <span class="bdg ${getBidangBdg(p.bidang)}">${bInfo.icon} ${bInfo.label}</span>
        </div>
        <div style="margin-left:auto;text-align:right">
          <div style="font-size:12px;color:var(--tx3)">${DB.jawaban.filter(j=>j.paketId===p.id&&siswaList.some(s=>s.id===j.siswaId)).length} / ${siswaList.length} siswa mengisi</div>
        </div>
      </div>`;

    // Top kebutuhan (berdasarkan skor terendah = paling butuh perhatian)
    const soalSkor = [];
    p.soal.forEach(q=>{
      if(!['likert','rating','slider'].includes(q.tipe)) return;
      const scores = [];
      siswaList.forEach(s=>{
        const jw = DB.jawaban.find(j=>j.siswaId===s.id&&j.paketId===p.id);
        if(!jw) return;
        const sk = hitungSkorSoal(q, jw.jawaban);
        if(sk!==null) scores.push(sk);
      });
      if(scores.length){
        const avg = scores.reduce((a,b)=>a+b,0)/scores.length;
        soalSkor.push({q, avg, count:scores.length});
      }
    });

    if(soalSkor.length){
      soalSkor.sort((a,b)=>a.avg-b.avg); // terendah = paling butuh perhatian
      html += `<div style="font-size:13px;font-weight:600;color:var(--tx2);margin-bottom:10px">📌 Urutan Prioritas Kebutuhan (skor rendah = butuh perhatian lebih):</div>`;
      html += `<div class="top-kebutuhan">`;
      soalSkor.forEach((item,i)=>{
        const {q,avg,count} = item;
        const pct = Math.round((avg-1)/4*100);
        const rankClass = i===0?'r1':i===1?'r2':i===2?'r3':'rn';
        const color = avg < 2.5 ? 'var(--red)' : avg < 3.5 ? 'var(--amber)' : 'var(--green)';
        html += `<div class="tk-item">
          <div class="tk-rank ${rankClass}">${i+1}</div>
          <div class="tk-info">
            <div class="tk-q">${q.teks}</div>
            <div class="tk-meta">
              <div class="pb" style="margin-top:6px"><div class="pf pf-bl" style="width:${pct}%;background:${color}"></div></div>
              <span style="font-size:11px;color:var(--tx3)">${count} respons</span>
            </div>
          </div>
          <div class="tk-skor" style="color:${color}">${avg.toFixed(2)}</div>
        </div>`;
      });
      html += `</div>`;
    }

    // Jawaban pilihan ganda (distribusi)
    p.soal.filter(q=>q.tipe==='pilihan'||q.tipe==='ganda').forEach(q=>{
      const freq = {};
      (q.opsi||[]).forEach(o=>freq[o]=0);
      siswaList.forEach(s=>{
        const jw = DB.jawaban.find(j=>j.siswaId===s.id&&j.paketId===p.id);
        if(!jw)return;
        const jawab = jw.jawaban[q.id];
        if(!jawab)return;
        String(jawab).split(', ').forEach(o=>{if(freq[o]!==undefined)freq[o]++;});
      });
      const total = Object.values(freq).reduce((a,b)=>a+b,0);
      if(total===0)return;
      html += `<div style="background:var(--sf2);border:1px solid var(--bd);border-radius:var(--rsm);padding:12px 14px;margin-top:10px">
        <div style="font-size:13px;font-weight:500;margin-bottom:10px">${q.teks}</div>`;
      Object.entries(freq).sort((a,b)=>b[1]-a[1]).forEach(([label,cnt])=>{
        const pct = total ? Math.round(cnt/total*100) : 0;
        html += `<div style="margin-bottom:6px">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px"><span>${label}</span><span><strong>${cnt}</strong> (${pct}%)</span></div>
          <div class="pb"><div class="pf pf-bl" style="width:${pct}%"></div></div>
        </div>`;
      });
      html += `</div>`;
    });

    html += `</div>`; // end paket card
  });

  cont.innerHTML = html;
}

function eksporAnalisisAKPD(){
  const kelasSel = document.getElementById('anAKPDkelas').value;
  const siswaList = kelasSel==='SEMUA'?DB.siswaList:DB.siswaList.filter(s=>s.kelas===kelasSel);
  const head = ['Nama','NIS','Kelas',...Object.keys(BIDANG).map(b=>`Skor ${BIDANG[b].label}`),'Rata-rata'];
  const rows = siswaList.map(s=>{
    const skorBidang = Object.keys(BIDANG).map(b=>{
      const bPaket = DB.akpdList.filter(p=>p.bidang===b);
      const allSk = [];
      bPaket.forEach(p=>{
        const jw = DB.jawaban.find(j=>j.siswaId===s.id&&j.paketId===p.id);
        if(!jw)return;
        p.soal.forEach(q=>{const sk=hitungSkorSoal(q,jw.jawaban);if(sk!==null)allSk.push(sk);});
      });
      return allSk.length?(allSk.reduce((a,b)=>a+b,0)/allSk.length).toFixed(2):'—';
    });
    const numSkor = skorBidang.filter(x=>x!=='—').map(Number);
    const avg = numSkor.length?(numSkor.reduce((a,b)=>a+b,0)/numSkor.length).toFixed(2):'—';
    return [`"${s.nama}"`,s.nis,s.kelas,...skorBidang,avg].join(',');
  });
  dlCSV([head.join(','),...rows].join('\n'), `Analisis_AKPD${kelasSel!=='SEMUA'?'_'+kelasSel.replace(/ /g,'_'):''}`);
}

