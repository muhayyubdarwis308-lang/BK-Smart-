// Hitung skor numerik untuk satu jawaban soal
function hitungSkorSoal(q, jawaban) {
  const j = jawaban[q.id];
  if(j === undefined || j === null || j === '') return null;
  if(q.tipe === 'likert') return parseInt(j);
  if(q.tipe === 'rating') return parseInt(j);
  if(q.tipe === 'slider') {
    const cfg = q.config || {};
    const mn = cfg.min ?? 0; const mx = cfg.max ?? 100;
    return Math.round(((parseInt(j) - mn) / (mx - mn)) * 4) + 1; // normalize ke 1-5
  }
  return null; // teks tidak dihitung numerik
}

